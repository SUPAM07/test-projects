               <property name="placeholderText">
                <string>Acknowledge number</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="lblFlags">
               <property name="text">
                <string>Flags</string>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QLineEdit" name="lineEditFlags">
               <property name="placeholderText">
                <string>Hex value</string>
               </property>
              </widget>
             </item>
             <item row="2" column="2">
              <widget class="QLabel" name="lblWindowSize">
               <property name="text">
                <string>Window Size</string>
               </property>
              </widget>
             </item>
             <item row="2" column="3">
              <widget class="QLineEdit" name="lineEditWindowSize">
               <property name="placeholderText">
                <string>e.g. 65535</string>
               </property>
              </widget>
             </item>
             <item row="3" column="2">
              <widget class="QLabel" name="lblWindowScale">
               <property name="text">
                <string>Window Scaling Factor</string>
               </property>
              </widget>
             </item>
             <item row="3" column="3">
              <widget class="QLineEdit" name="lineEditWindowScale">
               <property name="placeholderText">
                <string>e.g. 128</string>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QGroupBox" name="grpTLV">
            <property name="title">
             <string>TLV — Edit Existing Tag</string>
            </property>
            <layout class="QGridLayout" name="tlvGrid">
             <property name="horizontalSpacing">
              <number>10</number>
             </property>
             <property name="verticalSpacing">
              <number>8</number>
             </property>
             <item row="0" column="0">
              <widget class="QLabel" name="lblTagNo">
               <property name="text">
                <string>Tag No.</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QComboBox" name="comboTagNo">
               <property name="toolTip">
                <string>Auto-populated on Load Packet — lists all unique TLV tag numbers found in the loaded packet</string>
               </property>
              </widget>
             </item>
             <item row="0" column="2">
              <widget class="QLabel" name="lblPositionNo">
               <property name="text">
                <string>Occurrence</string>
               </property>
              </widget>
             </item>
             <item row="0" column="3">
              <widget class="QComboBox" name="comboPositionNo">
               <property name="toolTip">
                <string>Updated when Tag No. changes — lists how many times the selected tag appears</string>
               </property>
              </widget>
             </item>
             <item row="0" column="4">
              <widget class="QLabel" name="lblTLVValue">
               <property name="text">
                <string>Value</string>
               </property>
              </widget>
             </item>
             <item row="0" column="5">
              <widget class="QLineEdit" name="lineEditTLVValue">
               <property name="placeholderText">
                <string>Hex / ASCII</string>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="lblTLVType">
               <property name="text">
                <string>Type</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1" colspan="2">
              <widget class="QComboBox" name="comboTLVType">
               <item>
                <property name="text">
                 <string>Primitive</string>
                </property>
               </item>
               <item>
                <property name="text">
                 <string>Constructed</string>
                </property>
               </item>
              </widget>
             </item>
             <item row="1" column="3" colspan="3">
              <widget class="QLabel" name="lblTLVNote">
               <property name="styleSheet">
                <string>color: #484f58; font-size: 10px; font-style: italic;</string>
               </property>
               <property name="text">
                <string>ℹ  Tag No. and Occurrence dropdowns refresh automatically when Load Packet is clicked.</string>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QGroupBox" name="grpAddTLV">
            <property name="title">
             <string>Add New TLV Tag  —  Insert After Anchor Tag</string>
            </property>
            <layout class="QGridLayout" name="addTLVGrid">
             <property name="horizontalSpacing">
              <number>10</number>
             </property>
             <property name="verticalSpacing">
              <number>8</number>
             </property>
             <item row="0" column="0">
              <widget class="QLabel" name="lblNewTagNo">
               <property name="text">
                <string>New Tag No.</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QLineEdit" name="lineEditNewTagNo">
               <property name="placeholderText">
                <string>e.g. 0x61</string>
               </property>
              </widget>
             </item>
             <item row="0" column="2">
              <widget class="QLabel" name="lblNewValue">
               <property name="text">
                <string>Value</string>
               </property>
              </widget>
             </item>
             <item row="0" column="3" colspan="4">
              <widget class="QLineEdit" name="lineEditNewValue">
               <property name="placeholderText">
                <string>Hex / ASCII value for the new tag</string>
               </property>
              </widget>
             </item>
             <item row="1" column="0" colspan="7">
              <widget class="QLabel" name="lblAnchorHeader">
               <property name="styleSheet">
                <string>color: #58a6ff; font-size: 10px; font-weight: bold; padding: 2px 0;</string>
               </property>
               <property name="text">
                <string>  Anchor positions  —  new tag is inserted AFTER the Before anchor and BEFORE the After anchor</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="lblBeforeLabel">
               <property name="styleSheet">
                <string>color: #3fb950; font-weight: bold;</string>
               </property>
               <property name="text">
                <string>Before  ↓</string>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QLabel" name="lblBeforeTagNo">
               <property name="text">
                <string>Tag No.</string>
               </property>
              </widget>
             </item>
             <item row="2" column="2">
              <widget class="QComboBox" name="comboBeforeTagNo">
               <property name="toolTip">
                <string>New tag is inserted immediately after this tag's occurrence</string>
               </property>
              </widget>
             </item>
             <item row="2" column="3">
              <widget class="QLabel" name="lblBeforeOcc">
               <property name="text">
                <string>Occurrence</string>
               </property>
              </widget>
             </item>
             <item row="2" column="4">
              <widget class="QComboBox" name="comboBeforeOccurrence">
               <property name="toolTip">
                <string>Which occurrence of the Before tag to anchor after</string>
               </property>
              </widget>
             </item>
             <item row="2" column="5">
              <widget class="QPushButton" name="btnAddTLV">
               <property name="toolTip">
                <string>Insert the new TLV tag between the Before and After anchors</string>
               </property>
               <property name="text">
                <string>+ Insert Tag</string>
               </property>
              </widget>
             </item>
             <item row="2" column="6">
              <spacer name="horizontalSpacer">
               <property name="orientation">
                <enum>Qt::Horizontal</enum>
               </property>
               <property name="sizeHint" stdset="0">
                <size>
                 <width>40</width>
                 <height>20</height>
                </size>
               </property>
              </spacer>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </widget>
        <widget class="QWidget" name="tabOutput">
         <attribute name="title">
          <string>Output &amp; Save</string>
         </attribute>
         <layout class="QVBoxLayout" name="outputLayout">
          <property name="spacing">
           <number>8</number>
          </property>
          <property name="contentsMargins" stdset="0">
           <rect>
            <x>8</x>
            <y>8</y>
            <width>8</width>
            <height>8</height>
           </rect>
          </property>
          <item>
           <widget class="QGroupBox" name="grpSaveOptions">
            <property name="title">
             <string>Save Options</string>
            </property>
            <layout class="QGridLayout" name="saveGrid">
             <property name="horizontalSpacing">
              <number>14</number>
             </property>
             <property name="verticalSpacing">
              <number>10</number>
             </property>
             <item row="0" column="0">
              <widget class="QPushButton" name="btnSavePcap">
               <property name="text">
                <string>💾  Save PCAP</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QPushButton" name="btnSaveWholeTCP">
               <property name="toolTip">
                <string>Only enabled for MMS packet type</string>
               </property>
               <property name="text">
                <string>💾  Save Whole TCP Session</string>
               </property>
              </widget>
             </item>
             <item row="0" column="2">
              <widget class="QPushButton" name="btnLengthRange">
               <property name="text">
                <string>Length Range</string>
               </property>
              </widget>
             </item>
             <item row="0" column="3">
              <widget class="QCheckBox" name="chkSaveModifiedOnly">
               <property name="text">
                <string>Save Modified Packets Only</string>
               </property>
               <property name="checked">
                <bool>true</bool>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QPushButton" name="btnPrintTLV">
               <property name="text">
                <string>🖨  Print TLV</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1" colspan="2">
              <layout class="QHBoxLayout">
               <item>
                <widget class="QLabel" name="lblOutputFile">
                 <property name="text">
                  <string>Output File Name</string>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QLineEdit" name="lineEditOutputFile">
                 <property name="placeholderText">
                  <string>output.pcap</string>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
             <item row="1" column="3">
              <spacer>
               <property name="orientation">
                <enum>Qt::Horizontal</enum>
               </property>
               <property name="sizeHint" stdset="0">
                <size>
                 <width>40</width>
                 <height>20</height>
                </size>
               </property>
              </spacer>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QGroupBox" name="grpTerminal">
            <property name="title">
             <string>Terminal Output</string>
            </property>
            <layout class="QVBoxLayout" name="terminalVBox">
             <item>
              <layout class="QHBoxLayout">
               <item>
                <spacer>
                 <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                 </property>
                 <property name="sizeHint" stdset="0">
                  <size>
                   <width>40</width>
                   <height>20</height>
                  </size>
                 </property>
                </spacer>
               </item>
               <item>
                <widget class="QPushButton" name="btnClearTerminal">
                 <property name="text">
                  <string>Clear</string>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
             <item>
              <widget class="QTextEdit" name="terminalBox">
               <property name="readOnly">
                <bool>true</bool>
               </property>
               <property name="placeholderText">
                <string>[AIUS v1.0] Ready. Load a PCAP file to begin...
</string>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </widget>
       </widget>
      </item>
      <item>
       <widget class="QGroupBox" name="grpQuickTerminal">
        <property name="title">
         <string>Quick Log</string>
        </property>
        <layout class="QVBoxLayout">
         <item>
          <widget class="QTextEdit" name="quickTerminal">
           <property name="readOnly">
            <bool>true</bool>
           </property>
           <property name="placeholderText">
            <string>Status messages will appear here...</string>
           </property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="footerLayout">
        <property name="spacing">
         <number>6</number>
        </property>
        <property name="leftMargin">
         <number>9</number>
        </property>
        <property name="topMargin">
         <number>9</number>
        </property>
        <property name="rightMargin">
         <number>9</number>
        </property>
        <property name="bottomMargin">
         <number>9</number>
        </property>
        <property name="contentsMargins" stdset="0">
         <rect>
          <x>4</x>
          <y>0</y>
          <width>4</width>
          <height>0</height>
         </rect>
        </property>
        <item>
         <spacer>
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>40</width>
            <height>20</height>
           </size>
          </property>
         </spacer>
        </item>
        <item>
         <widget class="QLabel" name="lblFooterLeft">
          <property name="styleSheet">
           <string notr="true">color: #30363d; font-size: 12px; font-family: &quot;Consolas&quot;, monospace;</string>
          </property>
          <property name="text">
           <string>AIUS v1.0  ·  © 2026  Ayush Chand Ramola  ·  IISc | PGCoE</string>
          </property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>40</width>
            <height>20</height>
           </size>
          </property>
