   </rect>
  </property>
  <property name="windowTitle">
   <string>AIUS v1.0 — IEC 61850 Attack &amp; Intrusion Utility Suite</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QMainWindow { background-color: #0d1117; }
QWidget#centralwidget { background-color: #0d1117; }

/* ── Brand header ───────────────────────────────────────── */
QWidget#brandHeader {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0d1117, stop:0.3 #111820, stop:1 #0d1117);
    border-bottom: 1px solid #21262d;
}
QLabel#lblAppName {
    color: #58a6ff;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 22px;
    font-weight: bold;
    letter-spacing: 3px;
}
QLabel#lblAppSub {
    color: #3fb950;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 10px;
    letter-spacing: 2px;
}
QLabel#lblCreditLine {
    color: #484f58;
    font-size: 10px;
    font-style: italic;
}
QLabel#lblSponsor {
    color: #d4a72c;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 1px;
}
QLabel#lblVersion {
    color: #30363d;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 9px;
}

/* ── Groups ─────────────────────────────────────────────── */
QGroupBox {
    background-color: #161b22;
    border: 1px solid #30363d;
    border-radius: 6px;
    margin-top: 10px;
    padding-top: 8px;
    color: #58a6ff;
    font-weight: bold;
    font-size: 11px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    color: #58a6ff;
    font-size: 11px;
    font-weight: bold;
}
QGroupBox:disabled { border: 1px solid #21262d; background-color: #0d1117; }
QGroupBox:disabled &gt; QGroupBox::title { color: #3d444d; }

/* ── Controls ───────────────────────────────────────────── */
QLabel { color: #8b949e; font-size: 11px; }
QLineEdit {
    background-color: #21262d;
    border: 1px solid #30363d;
    border-radius: 4px;
    color: #e6edf3;
    padding: 4px 8px;
    font-size: 11px;
    selection-background-color: #1f6feb;
}
QLineEdit:focus { border: 1px solid #58a6ff; }
QLineEdit:disabled { background-color: #161b22; color: #3d444d; border-color: #21262d; }
QComboBox {
    background-color: #21262d;
    border: 1px solid #30363d;
    border-radius: 4px;
    color: #e6edf3;
    padding: 4px 8px;
    font-size: 11px;
    min-width: 80px;
}
QComboBox:focus { border: 1px solid #58a6ff; }
QComboBox:disabled { background-color: #161b22; color: #3d444d; border-color: #21262d; }
QComboBox::drop-down { border: none; width: 20px; }
QComboBox QAbstractItemView {
    background-color: #21262d;
    border: 1px solid #30363d;
    color: #e6edf3;
    selection-background-color: #1f6feb;
}
QPushButton {
    background-color: #21262d;
    border: 1px solid #30363d;
    border-radius: 4px;
    color: #e6edf3;
    padding: 5px 14px;
    font-size: 11px;
    font-weight: bold;
}
QPushButton:hover { background-color: #30363d; border-color: #58a6ff; }
QPushButton:disabled { background-color: #161b22; color: #3d444d; border-color: #21262d; }
QPushButton#btnLoad { background-color: #1f6feb; border: 1px solid #388bfd; color: #ffffff; }
QPushButton#btnLoad:hover { background-color: #388bfd; }
QPushButton#btnSavePcap { background-color: #238636; border: 1px solid #2ea043; color: #ffffff; }
QPushButton#btnSavePcap:hover { background-color: #2ea043; }
QPushButton#btnSaveWholeTCP { background-color: #6e40c9; border: 1px solid #8957e5; color: #ffffff; }
QPushButton#btnSaveWholeTCP:hover { background-color: #8957e5; }
QPushButton#btnPrintTLV { background-color: #b08800; border: 1px solid #d4a72c; color: #ffffff; }
QPushButton#btnPrintTLV:hover { background-color: #d4a72c; }
QPushButton#btnAddTLV { background-color: #21262d; border: 1px solid #30363d; color: #58a6ff; }
QPushButton#btnAddTLV:hover { background-color: #30363d; }
QCheckBox { color: #8b949e; font-size: 11px; spacing: 6px; }
QCheckBox::indicator { width: 14px; height: 14px; border: 1px solid #30363d; border-radius: 3px; background-color: #21262d; }
QCheckBox::indicator:checked { background-color: #1f6feb; border-color: #58a6ff; }
QCheckBox:disabled { color: #3d444d; }
QCheckBox::indicator:disabled { background-color: #161b22; border-color: #21262d; }
QRadioButton { color: #8b949e; font-size: 11px; spacing: 6px; }
QRadioButton::indicator { width: 14px; height: 14px; border: 1px solid #30363d; border-radius: 7px; background-color: #21262d; }
QRadioButton::indicator:checked { background-color: #1f6feb; border-color: #58a6ff; }
QTextEdit#terminalBox, QTextEdit#quickTerminal {
    background-color: #010409;
    border: 1px solid #30363d;
    border-radius: 4px;
    color: #3fb950;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 11px;
    padding: 6px;
}
QScrollBar:vertical { background: #161b22; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #30363d; border-radius: 4px; min-height: 20px; }
QScrollBar::handle:vertical:hover { background: #58a6ff; }
QTabWidget::pane { border: 1px solid #30363d; background-color: #0d1117; }
QTabBar::tab { background-color: #161b22; color: #8b949e; padding: 6px 16px; border: 1px solid #30363d; border-bottom: none; border-top-left-radius: 4px; border-top-right-radius: 4px; font-size: 11px; }
QTabBar::tab:selected { background-color: #0d1117; color: #58a6ff; border-bottom: 2px solid #58a6ff; }
QToolTip { background-color: #21262d; color: #e6edf3; border: 1px solid #58a6ff; border-radius: 4px; padding: 4px 8px; font-size: 11px; }
   </string>
